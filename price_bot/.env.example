# ---- Telegram (PFLICHT) --------------------------------------------------
TELEGRAM_TOKEN=123456:ABC-DEF_dein_token
TELEGRAM_CHAT_ID=123456789

# ---- Zielprodukt ---------------------------------------------------------
PRODUCT_URL=https://www.nintendo.com/de-de/Spiele/Nintendo-Switch-Download-Software/Marvel-s-Guardians-of-the-Galaxy-Cloud-Version-1987417.html
PRODUCT_NAME=Marvel's Guardians of the Galaxy (Cloud Version)

# Nintendo-System-UID. Wenn gesetzt, wird direkt die Preis-API abgefragt
# (schneller, zuverlaessiger). Wenn leer: der Bot parst die NSUID selbst
# aus der Produktseite.
NSUID=70010000042763

# ---- Uhrzeiten fuer taegliche Standard-Pushes ----------------------------
# Komma-separierte Stunden (0-23). Default: 6, 12 und 18 Uhr.
SCHEDULE_HOURS=6,12,18

# ---- Background-Check ----------------------------------------------------
# Wie oft im Hintergrund geprueft wird (Minuten). Standard: 15.
CHECK_INTERVAL_MIN=15

# ---- Preis-Alarme --------------------------------------------------------
# Sofortige Nachricht bei Preisaenderung zwischen zwei Checks.
ALERT_ON_CHANGE=true
# Faellt der Preis unter diese Schwelle -> ALARM_BURST_COUNT Nachrichten
# hintereinander.
LOW_PRICE_THRESHOLD=50.0
ALARM_BURST_COUNT=3

# ---- ntfy.sh Push-Nachrichten (KOSTENLOS, optional) ----------------------
# 1. App 'ntfy' auf dem Handy installieren (iOS/Android)
# 2. In der App: '+' -> Topic-Namen eintragen (moeglichst eindeutig)
# 3. Hier denselben Topic-Namen eintragen:
NTFY_TOPIC=
# optional:
# NTFY_SERVER=https://ntfy.sh
# NTFY_TOKEN=tk_...

# ---- SMS via Twilio (KOSTENPFLICHTIG, optional) --------------------------
# Alle 4 Werte ausfuellen, sonst wird SMS uebersprungen.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
SMS_TO=
